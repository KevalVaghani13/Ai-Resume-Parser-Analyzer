# Google Sheets API Configuration
GOOGLE_SHEET_ID=your_google_sheet_id_here
# Path to your service account JSON file (relative or absolute)
# Note: service_account.json is ignored by git for security
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json

# Optional for serverless deployments like Vercel:
# paste the raw service-account JSON into one env var, or a base64-encoded JSON string
# GOOGLE_SERVICE_ACCOUNT_JSON={...}
# GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=...

# OpenAI/LLM Configuration (if applicable)
# OPENAI_API_KEY=your_api_key_here

# App Settings
DEBUG=True
PORT=8000
